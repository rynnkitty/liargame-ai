# ===========================================
# LiarGame AI — 환경 변수 템플릿
# ===========================================
# 이 파일을 .env.local로 복사하여 사용하세요.
# cp .env.example .env.local

# -------------------------------------------
# 서버 설정
# -------------------------------------------

# 서버 포트 (IIS 배포 시 httpPlatformHandler가 자동 할당)
PORT=3000

# 환경 (development / production)
NODE_ENV=development

# -------------------------------------------
# Claude API (선택)
# -------------------------------------------
# API 키가 없으면 로컬 규칙 기반 AI로 동작합니다.
# API 키를 설정하면 Claude API 기반 고급 AI가 활성화됩니다.
#
# 방법 1: 서버 환경 변수로 설정 (모든 사용자 공유)
# ANTHROPIC_API_KEY=sk-ant-api03-...
#
# 방법 2: 클라이언트에서 개인 키 입력 (홈 화면 설정에서)
# → localStorage에 저장, 요청 시 x-api-key 헤더로 전송

# -------------------------------------------
# 게임 설정
# -------------------------------------------

# 최대 플레이어 수 (사람 + AI)
NEXT_PUBLIC_MAX_PLAYERS=8

# 최대 AI 플레이어 수
NEXT_PUBLIC_MAX_AI_PLAYERS=5
