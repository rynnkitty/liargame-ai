<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- httpPlatformHandler: Node.js 프로세스를 IIS 뒤에서 실행 -->
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath="node.exe"
                  arguments="dist\server\index.js"
                  startupTimeLimit="60"
                  requestTimeout="00:02:00"
                  stdoutLogEnabled="true"
                  stdoutLogFile="logs\node.log">
      <environmentVariables>
        <!-- IIS가 자동으로 할당한 포트를 Node.js에 전달 -->
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="NODE_ENV" value="production" />
        <!-- API 키를 직접 입력하세요 -->
        <environmentVariable name="ANTHROPIC_API_KEY" value="여기에_API_키_입력" />
        <!-- Claude 모델 선택: claude-haiku-4-5 / claude-sonnet-4-6 / claude-opus-4-6 -->
        <environmentVariable name="CLAUDE_MODEL" value="claude-haiku-4-5" />
      </environmentVariables>
    </httpPlatform>

    <!-- WebSocket 프로토콜 활성화 (Socket.IO 필수) -->
    <webSocket enabled="true" />

    <!-- 정적 파일 캐싱 (Next.js standalone _next/static) -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <!-- 보안 헤더 -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
